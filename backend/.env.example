# BYOK (Bring Your Own Key) — users configure their LLM API keys via Settings UI.
# ANTHROPIC_API_KEY here is honored ONLY when ALLOW_ENV_KEY_FALLBACK=true,
# useful for local dev so you don't have to log in just to test AI features.
ANTHROPIC_API_KEY=
# ALLOW_ENV_KEY_FALLBACK=true   # uncomment for local dev

# Database URL — SQLite is fine for self-hosting. PostgreSQL recommended for shared deployments.
# DATABASE_URL=sqlite:///./coding_bot.db
# DATABASE_URL=postgresql://user:password@host:5432/codingbot
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# Language for seed problems on first run: zh-CN | en-US | ja-JP | ko-KR
# SEED_LANGUAGE=zh-CN

# ─── Auth (REQUIRED for production) ───
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for API keys stored in DB
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=CHANGE_ME_IN_PRODUCTION

# ─── CORS (comma-separated allowed origins) ───
# CORS_ORIGINS=https://your-domain.com

# ─── Rate limiting (DoS protection) ───
# RATE_LIMIT_AI_PER_USER=60     # AI requests per user per minute
# RATE_LIMIT_AI_GLOBAL=500      # AI requests across all users per minute

# ─── Logging ───
# LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT=json              # json (production) | text (dev, human-readable)
# LOG_DIR=                     # empty = stdout only; set to dir path to also write rotating files
# LOG_FILE_MAX_BYTES=10485760  # 10 MB per file before rotation
# LOG_FILE_BACKUP_COUNT=5      # number of rotated files to keep
