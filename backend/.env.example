# BYOK (Bring Your Own Key) model: users configure their own keys via Settings.
# ANTHROPIC_API_KEY is honored ONLY when ALLOW_ENV_KEY_FALLBACK=true (dev only).
# In production, leave both EMPTY and ALLOW_ENV_KEY_FALLBACK unset/false so the
# platform never spends its own tokens.
ANTHROPIC_API_KEY=
# ALLOW_ENV_KEY_FALLBACK=true   # uncomment for local dev only

# Database URL (PostgreSQL for production, SQLite for local dev)
DATABASE_URL=postgresql://user:password@host:5432/codingbot
# DATABASE_URL=sqlite:///./coding_bot.db
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# Language for seed problems on first run: zh-CN | en-US | ja-JP | ko-KR
# SEED_LANGUAGE=zh-CN

# ─── Auth (REQUIRED for production) ───
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for API keys stored in DB
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=CHANGE_ME_IN_PRODUCTION

# ─── CORS (comma-separated allowed origins) ───
# CORS_ORIGINS=https://your-domain.com

# ─── Rate limiting (DoS protection — BYOK means platform doesn't pay tokens) ───
# RATE_LIMIT_AI_PER_USER=60     # AI requests per user per minute
# RATE_LIMIT_AI_GLOBAL=500      # AI requests across all users per minute

# ─── Subscription ───
# TRIAL_DAYS=7                  # free trial length on register
# SUBSCRIPTION_DAYS=30          # paid period per upgrade
# PLAN_MONTHLY_PRICE_CENTS=2900 # ¥29.00 per month (canonical price in cents)
# ENABLE_MOCK_BILLING=false     # dev/staging only — exposes /api/billing/upgrade
                                # WITHOUT verifying any payment. NEVER set true in prod
                                # if real payment providers are configured.

# ─── Alipay (支付宝, 用户扫码支付) ───
# Apply at https://open.alipay.com/ → 创建网页应用 → 扫码支付能力
# Leave empty to disable — /api/billing/checkout returns 503 for alipay if not set.
# ALIPAY_APP_ID=
# ALIPAY_APP_PRIVATE_KEY=        # full PEM string of YOUR app private key
# ALIPAY_PUBLIC_KEY=             # full PEM string of Alipay's public key (in console)
# ALIPAY_NOTIFY_URL=https://your-domain/api/billing/alipay/notify
# ALIPAY_RETURN_URL=https://your-domain/                # optional, browser redirect
# ALIPAY_SANDBOX=false           # true to use Alipay sandbox endpoint

# ─── WeChat Pay v3 (微信支付，用户扫码支付 Native) ───
# Apply at https://pay.weixin.qq.com/ → 商户平台 → API v3 密钥
# WECHAT_APP_ID=
# WECHAT_MCH_ID=
# WECHAT_API_V3_KEY=             # 32-char API v3 key set in 商户平台
# WECHAT_PRIVATE_KEY=            # full PEM string of merchant API certificate private key
# WECHAT_CERT_SERIAL_NO=         # cert serial in 商户平台 → API 证书页
# WECHAT_NOTIFY_URL=https://your-domain/api/billing/wechat/notify
# WECHAT_CERT_DIR=/var/lib/codingbot/wechat_certs       # writable cache dir for platform certs

# ─── Logging ───
# LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT=json              # json (production) | text (dev, human-readable)
# LOG_DIR=                     # empty = stdout only; set to dir path to also write rotating files
# LOG_FILE_MAX_BYTES=10485760  # 10 MB per file before rotation
# LOG_FILE_BACKUP_COUNT=5      # number of rotated files to keep
